# Proxmox Stack Maintainer configuration
# Installed to /etc/proxmox-stack-maintainer/config.env by install.sh.

# Space-separated VMIDs to skip as a fallback. Preferred skip method is the
# Proxmox GUI tag: no-auto-update
SKIP_IDS="600"

# Remove log files older than this many days.
LOG_RETENTION_DAYS="30"

# Post-maintenance HTTP health checks. Format: "Name=https://host:port/path"
# Add services here and they will be checked on every timer run.
SERVICE_CHECKS=(
  "Prismarr=http://10.12.0.30:7070"
  # "Sonarr=http://10.12.0.30:8989"
  # "Radarr=http://10.12.0.30:7878"
)
